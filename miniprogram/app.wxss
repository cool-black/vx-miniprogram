page {
  background: #fff8ef;
  color: #1d1d1f;
  font-family: Arial, sans-serif;
}

.screen {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.06);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.prompt {
  font-size: 34rpx;
  line-height: 1.5;
}

.hint {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #8a5d2f;
  background: #fff2de;
  border-radius: 18rpx;
  padding: 18rpx;
}

.keywords {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword {
  background: #f4eadf;
  color: #6f5134;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  font-size: 24rpx;
}

.button {
  margin-top: 28rpx;
  background: #e46b2e;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  padding: 24rpx;
  text-align: center;
}

.secondary-button {
  margin-top: 20rpx;
  background: #f2e4d3;
  color: #734625;
}

.status {
  font-size: 28rpx;
  color: #666666;
}

.error {
  margin-top: 20rpx;
  color: #b3351d;
  background: #ffe4db;
  border-radius: 16rpx;
  padding: 18rpx;
}
